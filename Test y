import dataiku
import pandas as pd

# ==========================
# Tables TRUSTED
# ==========================

trusted_tables = [
    "c_cash_flow",
    "c_direct_debit_cash_flow",
    "c_failed_cash_flow",
    "c_typ_cash_flow_failure_reason",
    "c_cash_flow_ctr_fin_cdt_invoice"
]

# ==========================
# Tables RAW
# ==========================

raw_tables = [
    "COR_fr_segmarche_v1",
    "COR_fr_lotfi_v1",
    "COR_fr_histoplot_v1",
    "COR_fr_echeancier_v1",
    "COR_fr_ktratp_v1"
]

all_tables = trusted_tables + raw_tables

inventory = []

for table_name in all_tables:

    try:

        ds = dataiku.Dataset(table_name)

        # Lecture minimale
        df = ds.get_dataframe(limit=1)

        for col in df.columns:

            inventory.append({
                "table_name": table_name,
                "column_name": col,
                "data_type": str(df[col].dtype)
            })

        print(f"OK : {table_name}")

    except Exception as e:

        print(f"ERREUR : {table_name}")
        print(str(e))

inventory_df = pd.DataFrame(inventory)

print("\nNombre total de colonnes :", len(inventory_df))

display(inventory_df)



# Regroupement par table

comparison = []

for trusted in trusted_tables:

    trusted_cols = set(
        inventory_df[
            inventory_df["table_name"] == trusted
        ]["column_name"]
    )

    for raw in raw_tables:

        raw_cols = set(
            inventory_df[
                inventory_df["table_name"] == raw
            ]["column_name"]
        )

        common = trusted_cols.intersection(raw_cols)

        comparison.append({
            "trusted_table": trusted,
            "raw_table": raw,
            "nb_common_columns": len(common)
        })

comparison_df = pd.DataFrame(comparison)

comparison_df = comparison_df.sort_values(
    "nb_common_columns",
    ascending=False
)

display(comparison_df)



# Détail des colonnes communes

trusted_table = "c_cash_flow"
