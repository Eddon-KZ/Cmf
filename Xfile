import dataiku
import pandas as pd

# Chargement datasets

raw = dataiku.Dataset("COR_fr_cash_flow_v1")
trusted = dataiku.Dataset("c_cash_flow")

df_raw = raw.get_dataframe(limit=1000)
df_trusted = trusted.get_dataframe(limit=1000)

print("RAW :", df_raw.shape)
print("TRUSTED :", df_trusted.shape)

# Colonnes

raw_cols = set(df_raw.columns)
trusted_cols = set(df_trusted.columns)

print("Nb colonnes RAW :", len(raw_cols))
print("Nb colonnes TRUSTED :", len(trusted_cols))

# Colonnes uniquement RAW

only_raw = sorted(raw_cols - trusted_cols)

print("\n=== Colonnes présentes uniquement dans RAW ===")
for c in only_raw:
    print(c)

# Colonnes uniquement TRUSTED

only_trusted = sorted(trusted_cols - raw_cols)

print("\n=== Colonnes présentes uniquement dans TRUSTED ===")
for c in only_trusted:
    print(c)

# Colonnes communes

common = sorted(raw_cols.intersection(trusted_cols))

print("\n=== Colonnes communes ===")
print(len(common))



comparison = []

for col in common:
    comparison.append({
        "column": col,
        "raw_type": str(df_raw[col].dtype),
        "trusted_type": str(df_trusted[col].dtype)
    })

schema_compare = pd.DataFrame(comparison)

schema_compare["same_type"] = (
    schema_compare["raw_type"] ==
    schema_compare["trusted_type"]
)

schema_compare



key = "ID_CASH_FLOW"

sample_ids = (
    df_trusted[key]
    .dropna()
    .unique()[:10]
)

raw_sample = df_raw[df_raw[key].isin(sample_ids)]
trusted_sample = df_trusted[df_trusted[key].isin(sample_ids)]

print("RAW records :", len(raw_sample))
print("TRUSTED records :", len(trusted_sample))
