# -*- coding: utf-8 -*-
import dataiku
import pandas as pd

# Read recipe inputs
SRW_contrat_manufacturers_filtered_v2 = dataiku.Dataset(
    "SRW_contrat_manufacturers_filtered_v2"
)
SRW_contrat_manufacturers_filtered_v2_df = (
    SRW_contrat_manufacturers_filtered_v2.get_dataframe()
)

SRW_c_clienp_v2 = dataiku.Dataset(
    "SRW_c_clienp_v2"
)
SRW_c_clienp_v2_df = (
    SRW_c_clienp_v2.get_dataframe()
)


# Contrats Italie
contrat_it_df = (
    SRW_contrat_manufacturers_filtered_v2_df[
        SRW_contrat_manufacturers_filtered_v2_df["tech_country"] == "ITA"
    ]
    .copy()
)

# Autres pays
contrat_other_df = (
    SRW_contrat_manufacturers_filtered_v2_df[
        SRW_contrat_manufacturers_filtered_v2_df["tech_country"] != "ITA"
    ]
    .copy()
)

# Table clients Italie
client_it_df = (
    SRW_c_clienp_v2_df[
        SRW_c_clienp_v2_df["tech_country"] == "ITA"
    ][["clpers", "id_fiscal_ita"]]
    .copy()
)

# Harmonisation des clés
client_it_df.rename(
    columns={"clpers": "ktpecc"},
    inplace=True
)

# Même type des deux côtés
contrat_it_df["ktpecc"] = contrat_it_df["ktpecc"].astype(str)
client_it_df["ktpecc"] = client_it_df["ktpecc"].astype(str)

# Jointure
contrat_it_df = contrat_it_df.merge(
    client_it_df,
    on="ktpecc",
    how="left"
)

# Remplacement du SIREN par l'id fiscal italien
contrat_it_df["ennusr"] = (
    contrat_it_df["id_fiscal_ita"]
    .fillna(contrat_it_df["ennusr"])
)

# Nettoyage
contrat_it_df.drop(
    columns=["id_fiscal_ita"],
    inplace=True
)

# Reconstruction du dataset
SRW_contrat_manufacturers_filtered_v3_df = pd.concat(
    [contrat_other_df, contrat_it_df],
    ignore_index=True
)

# Write recipe output
output_dataset = dataiku.Dataset(
    "SRW_contrat_manufacturers_filtered_v3"
)
output_dataset.write_with_schema(
    SRW_contrat_manufacturers_filtered_v3_df
)
