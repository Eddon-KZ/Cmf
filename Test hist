# -*- coding: utf-8 -*-

import logging
from datetime import datetime

import dataiku
import pandas as pd
from dateutil.relativedelta import relativedelta

# ==============================================================================
# CONFIGURATION
# ==============================================================================

SOURCE_DATASET = "ave_api_logs"
TARGET_DATASET = "ave_api_logs_hist"
TIMESTAMP_COLUMN = "timestamp"

# Nombre de mois à conserver dans la table chaude
# Exemple :
#   1 -> conserve le mois précédent
#   3 -> conserve les 3 derniers mois
RETENTION_MONTHS = 1

# ==============================================================================
# LOGGING
# ==============================================================================

logger = logging.getLogger(__name__)

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s"
)

logger.info("=" * 80)
logger.info("START - API LOGS ARCHIVING")

# ==============================================================================
# CALCUL DE LA DATE LIMITE D'ARCHIVAGE
# ==============================================================================

today = datetime.now()

archive_before_date = (
    today.replace(
        day=1,
        hour=0,
        minute=0,
        second=0,
        microsecond=0
    )
    - relativedelta(months=RETENTION_MONTHS)
)

logger.info(f"Retention period      : {RETENTION_MONTHS} month(s)")
logger.info(f"Archive data before   : {archive_before_date}")

# ==============================================================================
# LECTURE DE LA TABLE CHAUDE
# ==============================================================================

logger.info(f"Reading dataset '{SOURCE_DATASET}'...")

source_dataset = dataiku.Dataset(SOURCE_DATASET)
source_df = source_dataset.get_dataframe()

logger.info(f"Source rows : {len(source_df)}")

# ==============================================================================
# PREPARATION DES DONNEES
# ==============================================================================

logger.info("Preparing timestamp column...")

source_df = source_df[source_df[TIMESTAMP_COLUMN].notna()]
source_df = source_df[source_df[TIMESTAMP_COLUMN] != "Timestamp"]

source_df[TIMESTAMP_COLUMN] = pd.to_datetime(
    source_df[TIMESTAMP_COLUMN],
    errors="coerce"
)

source_df = source_df.dropna(subset=[TIMESTAMP_COLUMN])

logger.info(f"Valid rows : {len(source_df)}")

# ==============================================================================
# FILTRAGE DES DONNEES A ARCHIVER
# ==============================================================================

archive_df = source_df[
    source_df[TIMESTAMP_COLUMN] < archive_before_date
].copy()

archive_df = archive_df.drop_duplicates()

archive_count = len(archive_df)
kept_count = len(source_df) - archive_count

logger.info(f"Rows to archive        : {archive_count}")
logger.info(f"Rows kept in hot table : {kept_count}")

# ==============================================================================
# VARIABLES DE SCENARIO
# ==============================================================================

try:
    from dataiku.scenario import Scenario

    Scenario().set_scenario_variables(
        archive_count=str(archive_count),
        archive_before_date=archive_before_date.strftime("%Y-%m-%d")
    )

    logger.info("Scenario variables updated.")

except Exception:
    logger.info("Recipe executed outside a Dataiku Scenario.")

# ==============================================================================
# ECRITURE DE LA TABLE HISTORIQUE
# ==============================================================================

if archive_count == 0:

    logger.info("No data to archive.")
    logger.info("Historical table not updated.")
    logger.info("DELETE step should be skipped.")

else:

    logger.info(f"Writing dataset '{TARGET_DATASET}'...")

    target_dataset = dataiku.Dataset(TARGET_DATASET)

    target_dataset.write_with_schema(archive_df)

    logger.info("Historical table successfully updated.")

# ==============================================================================
# RESUME
# ==============================================================================

logger.info("=" * 80)
logger.info("ARCHIVE SUMMARY")
logger.info(f"Retention period      : {RETENTION_MONTHS} month(s)")
logger.info(f"Archive before        : {archive_before_date}")
logger.info(f"Source rows           : {len(source_df)}")
logger.info(f"Archived rows         : {archive_count}")
logger.info(f"Rows kept             : {kept_count}")
logger.info("=" * 80)

logger.info("END - API LOGS ARCHIVING")
